local function tr(key)
	local pack = TEXTS[currentLanguage] or TEXTS.vi
	return pack[key] or TEXTS.vi[key] or key
end

local function bindText(object, key, formatter)
	uiBindings[object] = { key = key, formatter = formatter }
	local value = tr(key)
	object.Text = formatter and formatter(value) or value
end

local function setZIndexRecursive(rootObject, zIndex)
	if not rootObject then
		return
	end
	pcall(function()
		rootObject.ZIndex = zIndex
	end)
	for _, child in ipairs(rootObject:GetDescendants()) do
		pcall(function()
			child.ZIndex = zIndex
		end)
	end
end

local function refreshTexts()
	for object, info in pairs(uiBindings) do
		if object and object.Parent then
			local value = tr(info.key)
			object.Text = info.formatter and info.formatter(value) or value
		end
	end
	fitWindowTitle()
	for lang, button in pairs(langButtons) do
		if button and button.Parent then
			local active = lang == currentLanguage
			button.BackgroundColor3 = active and UI_THEME.panelAccent or UI_THEME.langButton
			button.TextColor3 = active and UI_THEME.buttonActiveText or UI_THEME.textLang
		end
	end
end

