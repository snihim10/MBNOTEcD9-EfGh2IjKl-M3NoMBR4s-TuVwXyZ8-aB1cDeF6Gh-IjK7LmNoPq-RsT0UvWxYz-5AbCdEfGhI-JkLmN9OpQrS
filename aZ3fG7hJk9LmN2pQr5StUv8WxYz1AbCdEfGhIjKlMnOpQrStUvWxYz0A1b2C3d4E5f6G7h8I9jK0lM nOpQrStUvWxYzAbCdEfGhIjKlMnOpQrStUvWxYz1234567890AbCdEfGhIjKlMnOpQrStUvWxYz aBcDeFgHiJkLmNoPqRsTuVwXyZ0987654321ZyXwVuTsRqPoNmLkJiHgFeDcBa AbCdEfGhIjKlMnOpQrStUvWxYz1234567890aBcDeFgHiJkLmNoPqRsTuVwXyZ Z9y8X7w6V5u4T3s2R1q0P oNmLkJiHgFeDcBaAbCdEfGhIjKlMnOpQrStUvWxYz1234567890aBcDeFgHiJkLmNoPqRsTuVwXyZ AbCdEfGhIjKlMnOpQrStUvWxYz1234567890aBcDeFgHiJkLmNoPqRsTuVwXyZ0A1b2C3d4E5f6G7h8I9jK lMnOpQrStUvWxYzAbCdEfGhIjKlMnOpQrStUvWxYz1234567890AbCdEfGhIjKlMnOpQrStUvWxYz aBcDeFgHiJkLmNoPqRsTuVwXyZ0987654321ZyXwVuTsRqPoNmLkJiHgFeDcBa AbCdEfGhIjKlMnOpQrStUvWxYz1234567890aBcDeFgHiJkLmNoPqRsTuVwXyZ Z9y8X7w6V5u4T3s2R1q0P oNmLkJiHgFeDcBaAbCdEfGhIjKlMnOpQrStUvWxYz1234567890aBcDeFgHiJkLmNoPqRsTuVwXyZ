local function tweenButton(button, background, textColor)
	if hoverTweens[button] then
		hoverTweens[button]:Cancel()
	end
	local tween = TweenService:Create(button, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundColor3 = background,
		TextColor3 = textColor,
	})
	hoverTweens[button] = tween
	tween:Play()
end

