local function copyToClipboard(text)
	if type(text) ~= "string" or text == "" then
		return false
	end
	local clipboardSetters = {
		setclipboard,
		Clipboard and Clipboard.set,
		toclipboard,
		set_clipboard,
	}
	for _, setter in ipairs(clipboardSetters) do
		if type(setter) == "function" then
			local ok = pcall(setter, text)
			if ok then
				return true
			end
		end
	end
	return false
end

local function readAvatarCacheMeta(metaFile)
	if type(metaFile) ~= "string" or metaFile == "" then
		return nil, nil
	end
	if type(isfile) ~= "function" or type(readfile) ~= "function" then
		return nil, nil
	end
	local okExists, exists = pcall(isfile, metaFile)
	if not okExists or not exists then
		return nil, nil
	end
	local okRead, raw = pcall(readfile, metaFile)
	if not okRead or type(raw) ~= "string" or raw == "" then
		return nil, nil
	end
	local firstLine, secondLine
	for line in raw:gmatch("[^\r\n]+") do
		if not firstLine then
			firstLine = trimTextValue(line)
		elseif not secondLine then
			secondLine = trimTextValue(line)
			break
		end
	end
	return firstLine, secondLine
end

local function writeAvatarCacheMeta(metaFile, url)
	if type(metaFile) ~= "string" or metaFile == "" then
		return false
	end
	if type(writefile) ~= "function" or type(url) ~= "string" or url == "" then
		return false
	end
	local body = url .. "\n" .. CREDIT_AVATAR_CACHE_REVISION
	return pcall(writefile, metaFile, body)
end

local function resolveRemoteImageAsset(url, imageFile, metaFile)
	if type(url) ~= "string" or url == "" then
		return nil
	end
	if type(imageFile) ~= "string" or imageFile == "" then
		return nil
	end

	local customAsset = getCustomAssetFunction()
	if not customAsset then
		return nil
	end

	local cacheOk = false
	if type(metaFile) == "string" and metaFile ~= "" then
		local cachedUrl, cachedRev = readAvatarCacheMeta(metaFile)
		cacheOk = cachedUrl == url and cachedRev == CREDIT_AVATAR_CACHE_REVISION
	end

	if cacheOk and type(isfile) == "function" then
		local okExists, exists = pcall(isfile, imageFile)
		if okExists and exists then
			local okAsset, asset = pcall(customAsset, imageFile)
			if okAsset and type(asset) == "string" and asset ~= "" then
				return asset
			end
		end
	end

	if type(writefile) ~= "function" then
		return nil
	end

	local body
	local requestFn = getHttpRequestFunction()
	if requestFn then
		local okRequest, response = pcall(requestFn, {
			Url = url,
			Method = "GET",
		})
		if okRequest and type(response) == "table" then
			local success = (response.Success ~= false)
				and ((response.StatusCode == nil) or ((tonumber(response.StatusCode) or 0) < 400))
			if success and type(response.Body) == "string" and response.Body ~= "" then
				body = response.Body
			end
		end
	end

	if not body then
		local okFetch, rawBody = pcall(function()
			return game:HttpGet(url)
		end)
		if okFetch and type(rawBody) == "string" and rawBody ~= "" then
			body = rawBody
		end
	end

	if not body then
		return nil
	end

	local okWrite = pcall(writefile, imageFile, body)
	if not okWrite then
		return nil
	end

	if type(metaFile) == "string" and metaFile ~= "" then
		writeAvatarCacheMeta(metaFile, url)
	end

	local okAsset, asset = pcall(customAsset, imageFile)
	if okAsset and type(asset) == "string" and asset ~= "" then
		return asset
	end

	return nil
end

