	trackConnection(button.MouseEnter:Connect(function()
		if lang ~= currentLanguage then
			tweenButton(button, UI_THEME.langButtonHover, UI_THEME.textPrimary)
		end
	end))
	trackConnection(button.MouseLeave:Connect(function()
