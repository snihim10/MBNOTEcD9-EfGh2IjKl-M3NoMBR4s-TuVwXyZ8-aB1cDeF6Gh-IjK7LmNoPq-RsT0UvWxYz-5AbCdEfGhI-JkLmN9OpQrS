local function trimTextValue(value)
	if type(value) ~= "string" then
		return nil
	end
	local trimmed = value:match("^%s*(.-)%s*$")
	if trimmed == "" then
		return nil
	end
	return trimmed
end

local function parseThemeColor(value)
	if typeof(value) == "Color3" then
		return value
	end
	local txt = trimTextValue(value)
	if not txt then
		return nil
	end
	txt = txt:gsub("^rgb%s*%(", ""):gsub("%)$", "")
	local hex = txt:match("^#?(%x%x%x%x%x%x)$")
	if hex then
		return Color3.fromRGB(
			tonumber(hex:sub(1, 2), 16),
			tonumber(hex:sub(3, 4), 16),
			tonumber(hex:sub(5, 6), 16)
		)
	end
	local red, green, blue = txt:match("^(%-?%d+)%s*,%s*(%-?%d+)%s*,%s*(%-?%d+)$")
	if red and green and blue then
		return Color3.fromRGB(
			math.clamp(tonumber(red) or 0, 0, 255),
			math.clamp(tonumber(green) or 0, 0, 255),
			math.clamp(tonumber(blue) or 0, 0, 255)
		)
	end
	return nil
end

local function parseThemeConfig(rawText)
	local data = {}
	if type(rawText) ~= "string" or rawText == "" then
		return data
	end
	for line in rawText:gmatch("[^\r\n]+") do
		local clean = line:gsub("^%s+", ""):gsub("%s+$", "")
		if clean ~= "" and not clean:match("^#") and not clean:match("^%-%-") then
			local key, value = clean:match("^([%w_%.%-]+)%s*=%s*(.+)$")
			if key and value then
				data[key:lower()] = trimTextValue(value)
			end
		end
	end
	return data
end

local function resolveRemoteHeaderTitle(rawText)
	local trimmed = trimTextValue(rawText)
	if not trimmed then
		return nil
	end

	local okLoad, chunk = pcall(function()
		return loadstring(rawText)
	end)
	if okLoad and type(chunk) == "function" then
		local okResult, result = pcall(chunk)
		if okResult then
			if type(result) == "string" then
				return trimTextValue(result)
			end
			if type(result) == "table" then
				return trimTextValue(result.title)
					or trimTextValue(result.header)
					or trimTextValue(result.text)
					or trimTextValue(result[1])
			end
		end
	end

	local unquoted = trimmed:match('^"(.*)"$') or trimmed:match("^'(.*)'$")
	return trimTextValue(unquoted) or trimmed
end

local function fetchRemoteHeaderTitle(defaultTitle)
	local okResult, result = pcall(function()
		if type(loadstring) ~= "function" then
			return nil
		end
		local source = game:HttpGet(HEADER_SOURCE_URL)
		local chunk = loadstring(source)
		if type(chunk) ~= "function" then
			return nil
		end
		return chunk()
	end)
	if okResult then
		if type(result) == "string" then
			return trimTextValue(result) or defaultTitle
		end
		if type(result) == "table" then
			local resolved = trimTextValue(result.title)
				or trimTextValue(result.header)
				or trimTextValue(result.text)
				or trimTextValue(result[1])
			if resolved then
				return resolved
			end
		end
	end

	local okFetch, rawText = pcall(function()
		return game:HttpGet(HEADER_SOURCE_URL)
	end)
	if okFetch and type(rawText) == "string" then
		return resolveRemoteHeaderTitle(rawText) or defaultTitle
	end

	return defaultTitle
end

local function normalizeThemeTable(rawTheme)
	local normalized = {}
	if type(rawTheme) ~= "table" then
		return normalized
	end
	for key, value in pairs(rawTheme) do
		if type(key) == "string" then
			normalized[key:lower()] = value
		end
	end
	return normalized
end

local function fetchRemoteThemeConfig()
	local okResult, result = pcall(function()
		if type(loadstring) ~= "function" then
			return nil
		end
		local source = game:HttpGet(THEME_SOURCE_URL)
		local chunk = loadstring(source)
		if type(chunk) ~= "function" then
			return nil
		end
		return chunk()
	end)
	if okResult then
		if type(result) == "table" then
			return normalizeThemeTable(result)
		end
		if type(result) == "string" then
			return parseThemeConfig(result)
		end
	end

	local okRaw, raw = pcall(function()
		return game:HttpGet(THEME_SOURCE_URL)
	end)
	if okRaw and type(raw) == "string" and raw ~= "" then
		return parseThemeConfig(raw)
	end

	return {}
end

