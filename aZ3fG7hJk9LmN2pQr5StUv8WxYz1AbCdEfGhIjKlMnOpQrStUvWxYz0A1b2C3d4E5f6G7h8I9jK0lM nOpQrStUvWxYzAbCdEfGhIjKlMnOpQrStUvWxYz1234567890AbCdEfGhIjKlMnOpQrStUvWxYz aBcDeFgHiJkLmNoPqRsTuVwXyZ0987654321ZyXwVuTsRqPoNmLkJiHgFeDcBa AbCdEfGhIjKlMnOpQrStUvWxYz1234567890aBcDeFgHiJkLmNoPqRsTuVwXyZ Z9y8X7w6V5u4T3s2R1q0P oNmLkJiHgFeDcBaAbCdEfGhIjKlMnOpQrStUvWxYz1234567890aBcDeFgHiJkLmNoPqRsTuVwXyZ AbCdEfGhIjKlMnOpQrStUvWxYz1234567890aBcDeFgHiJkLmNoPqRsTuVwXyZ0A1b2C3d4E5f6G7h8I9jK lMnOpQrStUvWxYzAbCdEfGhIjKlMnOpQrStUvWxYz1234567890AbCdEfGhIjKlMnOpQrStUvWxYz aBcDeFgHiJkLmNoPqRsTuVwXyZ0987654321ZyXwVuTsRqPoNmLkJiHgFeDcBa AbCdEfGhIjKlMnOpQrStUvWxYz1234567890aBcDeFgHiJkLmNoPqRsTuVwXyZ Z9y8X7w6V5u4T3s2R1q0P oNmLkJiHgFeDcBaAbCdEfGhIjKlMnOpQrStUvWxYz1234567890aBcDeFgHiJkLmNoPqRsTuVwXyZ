local timeElapsed = 0
trackConnection(RunService.RenderStepped:Connect(function(dt)
	timeElapsed = timeElapsed + dt
	rootGradient.Rotation = 0
	mainStroke.Transparency = 0.12
	creatorStroke.Transparency = 0.1
	infoStroke.Transparency = 0.08

	for _, state in ipairs(digitLabels) do
		if SHOW_DIGIT_EFFECT and digitLayer.Visible then
			state.y = state.y + state.speed
			state.x = state.x + (math.sin(timeElapsed + state.y * 9) * state.drift * dt * 18)
			if state.y > 1.16 then
				respawnDigit(state, false)
			end
			state.object.Visible = true
			state.object.Position = UDim2.fromScale(state.x, state.y)
		else
			state.object.Visible = false
		end
	end
end))

