local function notifyButton(button, textKey, duration)
	local originalText = tr(textKey == "rejoinFailed" and "rejoin" or "close")
	local temporary = tr(textKey)
	button.Text = temporary
	task.delay(duration or 1.2, function()
		if button and button.Parent then
			if button == rejoinButton then
				button.Text = tr("rejoin")
			elseif button == closeButton then
				button.Text = tr("close")
			else
				button.Text = originalText
			end
		end
	end)
end

