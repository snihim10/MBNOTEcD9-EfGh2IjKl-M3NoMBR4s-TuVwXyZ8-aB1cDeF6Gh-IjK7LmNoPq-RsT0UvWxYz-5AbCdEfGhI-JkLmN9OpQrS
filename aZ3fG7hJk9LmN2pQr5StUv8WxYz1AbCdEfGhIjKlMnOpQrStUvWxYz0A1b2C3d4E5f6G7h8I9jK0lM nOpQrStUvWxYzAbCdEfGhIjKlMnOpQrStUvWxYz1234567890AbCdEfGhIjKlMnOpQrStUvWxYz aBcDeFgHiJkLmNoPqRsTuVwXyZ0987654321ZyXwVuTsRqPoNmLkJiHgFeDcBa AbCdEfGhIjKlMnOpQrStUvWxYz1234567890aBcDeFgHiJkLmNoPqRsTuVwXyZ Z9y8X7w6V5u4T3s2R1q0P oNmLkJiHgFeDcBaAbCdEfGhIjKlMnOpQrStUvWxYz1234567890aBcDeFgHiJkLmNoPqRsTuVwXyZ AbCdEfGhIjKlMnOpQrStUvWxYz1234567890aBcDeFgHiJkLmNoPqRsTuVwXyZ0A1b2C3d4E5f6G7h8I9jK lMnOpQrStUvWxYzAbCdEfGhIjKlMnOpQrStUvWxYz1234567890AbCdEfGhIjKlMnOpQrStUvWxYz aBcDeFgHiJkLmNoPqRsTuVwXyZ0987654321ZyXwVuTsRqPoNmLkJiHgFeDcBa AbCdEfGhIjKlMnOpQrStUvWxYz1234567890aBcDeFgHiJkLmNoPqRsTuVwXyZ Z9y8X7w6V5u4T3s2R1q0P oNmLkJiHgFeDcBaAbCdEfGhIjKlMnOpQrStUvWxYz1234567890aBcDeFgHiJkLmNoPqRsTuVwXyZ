local function randomDigitText()
	local length = math.random(1, 3)
	local out = table.create(length)
	for i = 1, length do
		local n = math.random(1, #digitPool)
		out[i] = digitPool:sub(n, n)
	end
	return table.concat(out)
end

local function respawnDigit(state, initial)
	state.x = math.random(6, 94) / 100
	state.y = initial and (math.random(0, 100) / 100) or (-0.16 - math.random() * 0.24)
	state.speed = math.random(18, 45) / 1000
	state.drift = (math.random() - 0.5) * 0.08
	state.size = math.random(10, 18)
	state.alpha = math.random(45, 72) / 100
	state.object.Text = randomDigitText()
	state.object.TextSize = state.size
	state.object.TextTransparency = state.alpha
end

