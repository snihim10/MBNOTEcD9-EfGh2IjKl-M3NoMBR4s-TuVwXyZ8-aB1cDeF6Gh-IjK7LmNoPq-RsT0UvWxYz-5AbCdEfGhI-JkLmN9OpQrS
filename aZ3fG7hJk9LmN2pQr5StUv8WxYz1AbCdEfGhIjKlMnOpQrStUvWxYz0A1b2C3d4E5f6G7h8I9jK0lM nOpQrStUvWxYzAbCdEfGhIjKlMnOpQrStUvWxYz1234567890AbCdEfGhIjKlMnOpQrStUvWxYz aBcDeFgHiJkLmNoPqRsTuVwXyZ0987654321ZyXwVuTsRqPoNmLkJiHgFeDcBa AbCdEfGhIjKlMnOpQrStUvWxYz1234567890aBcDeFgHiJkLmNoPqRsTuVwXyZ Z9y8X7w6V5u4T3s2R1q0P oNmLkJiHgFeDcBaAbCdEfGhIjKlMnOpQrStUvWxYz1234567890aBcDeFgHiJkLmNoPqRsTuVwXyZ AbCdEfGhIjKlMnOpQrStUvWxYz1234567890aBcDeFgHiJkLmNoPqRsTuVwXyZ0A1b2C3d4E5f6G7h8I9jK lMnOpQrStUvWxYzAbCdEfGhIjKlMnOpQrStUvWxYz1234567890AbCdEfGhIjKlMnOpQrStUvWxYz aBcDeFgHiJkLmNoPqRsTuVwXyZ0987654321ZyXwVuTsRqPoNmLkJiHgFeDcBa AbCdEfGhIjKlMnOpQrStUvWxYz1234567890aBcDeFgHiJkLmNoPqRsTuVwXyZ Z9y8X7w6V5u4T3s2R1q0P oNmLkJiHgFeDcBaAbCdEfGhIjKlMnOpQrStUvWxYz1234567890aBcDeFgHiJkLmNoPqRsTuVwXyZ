local function fitWindowTitle()
	if not titleLabel or not titleLabel.Parent then
		return
	end
	local availableWidth = math.max(titleLabel.AbsoluteSize.X, 1)
	local availableHeight = math.max(titleLabel.AbsoluteSize.Y, 1)
	local text = titleLabel.Text or ""
	local textSize = TITLE_MAX_TEXT_SIZE
	while textSize > TITLE_MIN_TEXT_SIZE do
		local bounds = TextService:GetTextSize(text, textSize, titleLabel.Font, Vector2.new(10000, availableHeight))
		if bounds.X <= availableWidth then
			break
		end
		textSize = textSize - 1
	end
	titleLabel.TextSize = textSize
	titleLabel.TextTruncate = Enum.TextTruncate.AtEnd
end

