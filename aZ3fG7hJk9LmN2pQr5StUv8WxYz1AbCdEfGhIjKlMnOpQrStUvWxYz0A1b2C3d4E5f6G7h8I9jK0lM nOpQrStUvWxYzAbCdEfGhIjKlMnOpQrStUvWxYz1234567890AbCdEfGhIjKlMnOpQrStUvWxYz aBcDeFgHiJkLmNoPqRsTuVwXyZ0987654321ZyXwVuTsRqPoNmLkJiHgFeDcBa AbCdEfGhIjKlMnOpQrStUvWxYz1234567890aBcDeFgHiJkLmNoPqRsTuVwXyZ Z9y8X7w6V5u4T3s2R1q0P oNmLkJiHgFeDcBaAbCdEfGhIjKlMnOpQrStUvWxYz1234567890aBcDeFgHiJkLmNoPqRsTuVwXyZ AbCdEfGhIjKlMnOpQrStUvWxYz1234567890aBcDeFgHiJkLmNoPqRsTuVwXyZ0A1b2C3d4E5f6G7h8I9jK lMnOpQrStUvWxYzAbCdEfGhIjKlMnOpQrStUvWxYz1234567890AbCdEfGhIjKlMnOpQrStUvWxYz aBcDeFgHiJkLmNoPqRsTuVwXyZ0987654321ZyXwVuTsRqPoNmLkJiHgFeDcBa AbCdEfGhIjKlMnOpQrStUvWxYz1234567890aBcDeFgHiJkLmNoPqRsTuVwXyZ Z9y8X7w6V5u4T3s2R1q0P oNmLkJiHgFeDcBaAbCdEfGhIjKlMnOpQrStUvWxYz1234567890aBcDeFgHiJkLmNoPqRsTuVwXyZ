task.defer(function()
	pcall(function()
		local thumb = Players:GetUserThumbnailAsync(CREDIT_USER_ID, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
		if thumb and thumb ~= "" then
			creatorAvatar.Image = thumb
		end
	end)
end)

closeButton.MouseEnter:Connect(function()
	TweenService:Create(closeButton, buttonTweenInfo, {BackgroundColor3 = palette.accent}):Play()
end)

closeButton.MouseLeave:Connect(function()
	TweenService:Create(closeButton, buttonTweenInfo, {BackgroundColor3 = palette.accentSoft}):Play()
end)

closeButton.Activated:Connect(function()
	local shrink = TweenService:Create(scale, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Scale = 0.92})
	local fadePanel = TweenService:Create(panel, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1})
	local fadeShadow = TweenService:Create(panelShadow, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {ImageTransparency = 1})
	shrink:Play()
	fadePanel:Play()
	fadeShadow:Play()
	shrink.Completed:Connect(function()
		screenGui:Destroy()
	end)
end)

UserInputService:GetPropertyChangedSignal("TouchEnabled"):Connect(function()
	mobileHint.Text = UserInputService.TouchEnabled and "Thiết bị: Mobile" or "Thiết bị: Desktop"
end)

if workspace.CurrentCamera then
	workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(updateLayout)
end

updateLayout()
