local function readSavedLanguage()
	if type(isfile) ~= "function" or type(readfile) ~= "function" then
		return nil
	end
	local okExists, exists = pcall(isfile, LANGUAGE_FILE)
	if not okExists or not exists then
		return nil
	end
	local okRead, raw = pcall(readfile, LANGUAGE_FILE)
	if not okRead or type(raw) ~= "string" then
		return nil
	end
	local clean = raw:match("^%s*(.-)%s*$")
	if TEXTS[clean] then
		return clean
	end
	return nil
end

local function saveLanguage(lang)
	if type(writefile) ~= "function" or not TEXTS[lang] then
		return false
	end
	return pcall(writefile, LANGUAGE_FILE, lang)
end

