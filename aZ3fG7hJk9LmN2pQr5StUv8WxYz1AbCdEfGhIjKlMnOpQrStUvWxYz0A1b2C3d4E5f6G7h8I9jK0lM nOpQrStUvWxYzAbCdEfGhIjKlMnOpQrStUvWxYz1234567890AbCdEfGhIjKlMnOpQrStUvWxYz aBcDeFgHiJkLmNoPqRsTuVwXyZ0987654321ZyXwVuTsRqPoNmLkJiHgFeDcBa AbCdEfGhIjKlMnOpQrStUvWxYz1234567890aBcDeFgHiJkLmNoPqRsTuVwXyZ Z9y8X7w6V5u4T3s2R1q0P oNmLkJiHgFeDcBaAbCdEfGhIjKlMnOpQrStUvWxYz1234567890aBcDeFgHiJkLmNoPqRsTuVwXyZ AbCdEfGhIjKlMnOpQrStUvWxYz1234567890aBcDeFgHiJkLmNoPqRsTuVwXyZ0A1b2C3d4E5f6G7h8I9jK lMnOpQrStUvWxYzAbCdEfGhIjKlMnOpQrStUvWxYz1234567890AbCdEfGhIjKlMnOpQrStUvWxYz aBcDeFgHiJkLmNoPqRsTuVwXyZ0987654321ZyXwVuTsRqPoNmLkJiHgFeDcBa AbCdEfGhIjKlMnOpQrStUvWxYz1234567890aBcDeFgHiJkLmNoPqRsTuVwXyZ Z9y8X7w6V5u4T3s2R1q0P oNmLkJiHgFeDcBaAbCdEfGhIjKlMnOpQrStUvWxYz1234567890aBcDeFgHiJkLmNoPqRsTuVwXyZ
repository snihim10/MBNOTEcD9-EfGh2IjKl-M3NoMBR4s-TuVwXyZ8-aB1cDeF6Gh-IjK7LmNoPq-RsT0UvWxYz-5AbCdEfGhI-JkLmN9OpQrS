local function updateLayout()
	local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280, 720)
	local minAxis = math.min(viewport.X, viewport.Y)
	local computedScale = math.clamp(minAxis / 720, 0.68, 1)
	scale.Scale = computedScale

	if viewport.X < 700 then
		panel.Size = UDim2.fromOffset(460, 320)
		title.TextSize = 24
		body.TextSize = 15
		closeButton.Position = UDim2.new(1, -28, 1, -34)
		footer.Size = UDim2.new(1, -170, 0, 44)
		footer.Position = UDim2.fromOffset(28, 228)
		mobileHint.Position = UDim2.new(1, -28, 0, 34)
	else
		panel.Size = UDim2.fromOffset(610, 290)
		title.TextSize = 29
		body.TextSize = 17
		closeButton.Position = UDim2.new(1, -28, 0.5, 102)
		footer.Size = UDim2.new(1, -150, 0, 36)
		footer.Position = UDim2.fromOffset(28, 224)
		mobileHint.Position = UDim2.new(1, -28, 0.5, -102)
	end

	if viewport.X < 480 then
		badge.Size = UDim2.fromOffset(158, 32)
		badge.TextSize = 13
		title.TextSize = 21
		body.TextSize = 14
		panel.Size = UDim2.fromOffset(400, 336)
		body.Size = UDim2.new(1, -56, 0, 76)
		divider.Position = UDim2.fromOffset(28, 228)
		footer.Position = UDim2.fromOffset(28, 242)
		closeButton.Size = UDim2.fromOffset(96, 38)
	else
		body.Size = UDim2.new(1, -56, 0, 56)
		divider.Position = UDim2.fromOffset(28, 208)
		closeButton.Size = UDim2.fromOffset(108, 40)
	end
end

local panelTweenInfo = TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local buttonTweenInfo = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

TweenService:Create(scale, panelTweenInfo, {Scale = 1}):Play()
